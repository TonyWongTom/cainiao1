rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Helper Definitions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Players Collection ---
    match /players/{playerId} {
      allow get: if isValidId(playerId);
      allow list: if true;
      
      function isValidPlayer(data) {
        return data.keys().hasAll(['id', 'name', 'type', 'defaultFee', 'isFunder']) 
          && data.id is string && data.id.size() <= 64
          && data.name is string && data.name.size() <= 100
          && data.type in ['包月', '包半月', '按次'];
      }

      allow create: if isValidPlayer(incoming()) && isValidId(playerId);
      
      allow update: if isValidPlayer(incoming()) 
        && incoming().id == existing().id 
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'type', 'defaultFee', 'isFunder'])
        );
      
      allow delete: if true;
    }

    // --- Periods Collection ---
    match /periods/{periodId} {
      allow get: if isValidId(periodId);
      allow list: if true;

      function isValidPeriod(data) {
        return data.keys().hasAll(['id', 'name', 'startDate', 'endDate', 'courtCost', 'sessions', 'funderIds'])
          && data.id is string && data.id.size() <= 64
          && data.name is string && data.name.size() <= 200;
      }

      allow create: if isValidPeriod(incoming()) && isValidId(periodId);

      allow update: if isValidPeriod(incoming())
        && incoming().id == existing().id
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'startDate', 'endDate', 'courtCost', 'sessions', 'funderIds', 'playerConfigs'])
        );

      allow delete: if true;
    }

    // --- Test Collection (for connection check) ---
    match /test/connection {
      allow get: if true;
    }
  }
}
